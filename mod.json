{
    "geode": "5.7.1",
    "gd": {
        "win": "2.2081",
        "android": "2.2081",
        "mac": "2.2081",
        "ios": "2.2081"
    },

    "version": "v1.0.1",
    "id": "undefined0.draggable-popups",
    "name": "Draggable Popups",
    "developer": "undefined0",
    "description": "Allows you to drag popups! Useful in the editor, to preview options.",
    "tags": [ "universal", "editor", "interface" ],

    "dependencies": {
        "alphalaneous.alphas-ui-pack": "v1.0.0"
    },

    "links": {
        "source": "https://github.com/undefined06855/Draggable-Popups"
    },

    "resources": {
        "sprites": [ "resources/*.png" ]
    },

    "settings": {
        "mouse-button": {
            "type": "string",
            "name": "Mouse Button",
            "default": "Right",
            "one-of": [ "Left", "Middle", "Right" ],
            "platforms": [ "desktop" ]
        },
        "modifier-keys": {
            "type": "string",
            "name": "Modifier Keys",
            "default": "None",
            "one-of": [ "None", "Ctrl", "Alt", "Shift", "Ctrl+Shift", "Ctrl+Alt", "Alt+Shift", "Ctrl+Alt+Shift" ],
            "platforms": [ "desktop" ]
        },
        "enable-close-target": {
            "type": "bool",
            "name": "Enable Close Target",
            "description": "Enables a button in the bottom middle which a popup can be dragged into to close it. Similar to Android's Picture-In-Picture close action.",
            "default": true
        }
    }
}
